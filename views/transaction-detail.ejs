<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head', { title: 'Transaction Details - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <%- include('partials/messages') %>

            <%
            // Compute permissions based on role
            const canEdit = isAdmin || transaction.status === 'pending';
            const canDelete = isAdmin || transaction.status === 'pending';
            %>

            <!-- Header Row -->
            <div class="flex items-center gap-base mb-base">
                <a href="<%= backUrl %>" class="btn btn-sm btn-secondary">&larr; Back</a>
                <h1 class="m-0">Transaction</h1>
            </div>

            <!-- Metadata Row -->
            <div class="mb-lg text-sm text-muted">
                #<%= transaction.id %> · <%= transaction.status.toUpperCase() %> · <%= transaction.band_name %> · <%= new Date(transaction.created_at).toLocaleDateString() %>
            </div>

            <!-- Details Card -->
            <div class="card mb-lg">
                <% if (canEdit) { %>
                    <%- include('partials/transaction-form', {
                        formAction: urlPrefix + '/' + transaction.id + '/edit',
                        transaction: transaction,
                        categories: categories,
                        canEditStatus: isAdmin,
                        canEditDate: canEdit
                    }) %>
                <% } else { %>
                    <!-- Read-only view with grid layout -->
                    <div class="form-row-2 mb-base">
                        <div>
                            <p class="form-label">Type</p>
                            <p><%= transaction.type.charAt(0).toUpperCase() + transaction.type.slice(1) %></p>
                        </div>
                        <div>
                            <p class="form-label">Category</p>
                            <p><%= transaction.category_name %></p>
                        </div>
                    </div>
                    <div class="form-row-2 mb-base">
                        <div>
                            <p class="form-label">Amount</p>
                            <p class="text-lg"><%= transaction.type === 'expense' ? '-' : '+' %><%= transaction.amount.toFixed(2) %> &euro;</p>
                        </div>
                        <div>
                            <p class="form-label">Transaction Date</p>
                            <p><%= transaction.transaction_date ? new Date(transaction.transaction_date).toLocaleDateString() : '-' %></p>
                        </div>
                    </div>
                    <div class="mb-base">
                        <p class="form-label">Description</p>
                        <pre class="bg-accent p-base"><%= transaction.description %></pre>
                    </div>
                <% } %>
            </div>

            <!-- Qonto Transaction Linker (Admin Only) - Moved up -->
            <%- include('partials/qonto-linker', {
                isAdmin: isAdmin,
                transaction: transaction,
                linkedQontoTransactions: linkedQontoTransactions || [],
                band: band
            }) %>

            <!-- Document Management -->
            <div class="card mb-lg">
                <% if (transaction.drive_folder_id) { %>
                    <div class="flex items-center justify-between flex-wrap gap-base mb-base">
                        <h2 class="card-title m-0">Documents</h2>
                        <a href="https://drive.google.com/drive/folders/<%= transaction.drive_folder_id %>" target="_blank" class="btn btn-sm btn-secondary">
                            View in Drive &rarr;
                        </a>
                    </div>
                <% } else { %>
                    <h2 class="card-title">Documents</h2>
                <% } %>

                <% if (!transaction.drive_folder_id) { %>
                    <!-- No folder exists -->
                    <p class="mb-base">No documents folder yet.</p>
                    <form id="create-folder-form" action="<%= urlPrefix %>/<%= transaction.id %>/create-folder" method="POST">
                        <button type="submit" class="btn" id="create-folder-btn">Create Documents Folder</button>
                    </form>
                <% } else { %>
                    <!-- Folder exists - show documents -->
                    <% if (documents && documents.length > 0) { %>
                        <div class="table-wrapper mb-base">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Filename</th>
                                        <th>Uploaded</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% documents.forEach(doc => { %>
                                        <tr>
                                            <td>
                                                <a href="https://drive.google.com/file/d/<%= doc.drive_file_id %>/view" target="_blank">
                                                    <%= doc.filename %>
                                                </a>
                                            </td>
                                            <td><%= new Date(doc.uploaded_at).toLocaleDateString() %></td>
                                            <td>
                                                <form action="<%= urlPrefix %>/<%= transaction.id %>/documents/<%= doc.id %>/delete" method="POST" class="m-0">
                                                    <button type="submit" class="btn btn-sm btn-error" onclick="return confirm('Delete this document?')">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="mb-base text-muted">No documents yet.</p>
                    <% } %>

                    <!-- Upload form -->
                    <form id="upload-form" action="<%= urlPrefix %>/<%= transaction.id %>/documents" method="POST" enctype="multipart/form-data">
                        <div class="flex items-center gap-base">
                            <input
                                type="file"
                                id="documents"
                                name="documents"
                                class="form-input"
                                style="flex: 1;"
                                multiple
                                accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx"
                                required
                            >
                            <button type="submit" class="btn btn-primary" id="upload-btn">Upload</button>
                        </div>
                    </form>
                <% } %>
            </div>

            <!-- Delete Transaction -->
            <% if (canDelete) { %>
                <div class="text-right">
                    <form action="<%= urlPrefix %>/<%= transaction.id %>/delete" method="POST" class="m-0">
                        <button type="submit" class="btn btn-sm btn-error" onclick="return confirm('<%= transaction.status === 'validated' ? 'This transaction is validated. Really delete?' : 'Delete this transaction?' %>')">
                            Delete Transaction
                        </button>
                    </form>
                </div>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/transaction-detail.js"></script>
</body>
</html>
