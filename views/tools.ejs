<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Tools - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">Tools</h1>
            <%- include('partials/messages') %>

            <p class="mb-xl">
                Available tools for managing your business.
            </p>

            <div class="card-grid">
                <% tools.forEach(tool => { %>
                    <a href="<%= tool.href %>" class="card card-clickable">
                        <h2 class="card-title"><%= tool.name %></h2>
                        <p><%= tool.description %></p>
                    </a>
                <% }); %>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
