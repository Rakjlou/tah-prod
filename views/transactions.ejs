<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head', { title: 'Transactions - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">My Transactions</h1>
            <%- include('partials/messages') %>

            <div class="card mb-xl">
                <div class="flex justify-between items-center mb-lg flex-wrap gap-base">
                    <div>
                        <p class="text-lg mb-sm">
                            <strong>Current Balance:</strong> <%= balance.toFixed(2) %> &euro;
                        </p>
                        <% if (pendingCount > 0) { %>
                            <p class="small muted">
                                (<%= pendingCount %> pending transaction<%= pendingCount > 1 ? 's' : '' %>)
                            </p>
                        <% } %>
                    </div>
                    <div>
                        <a href="/transactions/new" class="btn btn-primary">Create Transaction</a>
                    </div>
                </div>

                <div class="mb-lg flex gap-sm flex-wrap">
                    <a
                        href="/transactions"
                        class="btn btn-sm <%= !statusFilter ? 'active' : '' %>"
                    >
                        All
                    </a>
                    <a
                        href="/transactions?status=pending"
                        class="btn btn-sm <%= statusFilter === 'pending' ? 'active' : '' %>"
                    >
                        Pending
                    </a>
                    <a
                        href="/transactions?status=validated"
                        class="btn btn-sm <%= statusFilter === 'validated' ? 'active' : '' %>"
                    >
                        Validated
                    </a>
                </div>

                <%- include('partials/transaction-table', {
                    transactions,
                    showBandColumn: false,
                    detailUrlPrefix: '/transactions'
                }) %>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
