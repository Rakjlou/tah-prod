<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Reconciliation Dashboard' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">Qonto Reconciliation Dashboard</h1>

            <%- include('partials/messages') %>

            <!-- Summary Stats -->
            <div class="stat-grid mb-xl">
                <div class="stat-card">
                    <div class="stat-label">Total Discrepancies</div>
                    <div class="stat-value <%= stats.total > 0 ? 'stat-warning' : 'stat-success' %>">
                        <%= stats.total %>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Difference</div>
                    <div class="stat-value <%= parseFloat(stats.totalDifference) > 0 ? 'stat-warning' : 'stat-success' %>">
                        <%= stats.totalDifference %> €
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Pending</div>
                    <div class="stat-value"><%= stats.pending %></div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Validated</div>
                    <div class="stat-value"><%= stats.validated %></div>
                </div>
            </div>

            <!-- Filters -->
            <div class="card mb-lg">
                <form method="GET" action="/admin/reconciliation" class="flex gap-base items-end flex-wrap">
                    <div class="form-group mb-0">
                        <label for="band" class="form-label">Band</label>
                        <select name="band" id="band" class="form-select">
                            <option value="">All Bands</option>
                            <% bands.forEach(band => { %>
                                <option value="<%= band.id %>" <%= bandFilter == band.id ? 'selected' : '' %>>
                                    <%= band.name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group mb-0">
                        <label for="status" class="form-label">Status</label>
                        <select name="status" id="status" class="form-select">
                            <option value="">All Statuses</option>
                            <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="validated" <%= statusFilter === 'validated' ? 'selected' : '' %>>Validated</option>
                        </select>
                    </div>

                    <button type="submit" class="btn">Filter</button>
                    <% if (bandFilter || statusFilter) { %>
                        <a href="/admin/reconciliation" class="btn btn-secondary">Clear Filters</a>
                    <% } %>
                </form>
            </div>

            <!-- Discrepancies Table -->
            <% if (discrepancies.length === 0) { %>
                <div class="message message-success">
                    <p>No discrepancies found. All linked transactions match their Qonto amounts.</p>
                </div>
            <% } else { %>
                <div class="table-wrapper">
                <table class="table">
                <thead>
                    <tr>
                        <th>Transaction ID</th>
                        <th>Band</th>
                        <th>Website Amount</th>
                        <th>Expected Qonto Total</th>
                        <th>Actual Qonto Total</th>
                        <th>Difference</th>
                        <th>Status</th>
                        <th>Links</th>
                        <th>Issues</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% discrepancies.forEach(disc => { %>
                        <tr>
                            <td><%= disc.transaction.id %></td>
                            <td><%= disc.transaction.band_name %></td>
                            <td>
                                <span class="amount <%= disc.transaction.type %>">
                                    <%= disc.transaction.type === 'expense' ? '-' : '+' %><%= disc.transaction.amount.toFixed(2) %> €
                                </span>
                            </td>
                            <td><%= disc.expectedAmount.toFixed(2) %> €</td>
                            <td><%= disc.linkedAmounts.toFixed(2) %> €</td>
                            <td class="difference-cell <%= disc.difference > 0 ? 'has-difference' : '' %>">
                                <%= disc.difference.toFixed(2) %> €
                            </td>
                            <td>
                                <span class="badge badge-<%= disc.transaction.status %>">
                                    <%= disc.transaction.status.toUpperCase() %>
                                </span>
                            </td>
                            <td><%= disc.linkCount %></td>
                            <td class="issues-cell">
                                <% if (!disc.isAmountMatch) { %>
                                    <span class="issue-badge">Amount Mismatch</span>
                                <% } %>
                                <% if (disc.directionIssues.length > 0) { %>
                                    <span class="issue-badge">Direction Error</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/admin/transactions/<%= disc.transaction.id %>" class="btn btn-sm">View</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
            </div>
        <% } %>

            <div class="mt-xl">
                <a href="/admin/transactions" class="btn btn-secondary">Back to Transactions</a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
