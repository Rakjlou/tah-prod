<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head', { title: 'My Account - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">My Account</h1>
            <%- include('partials/messages') %>

            <% if (band) { %>
                <div class="card mb-lg">
                    <h2 class="card-title">Band Information</h2>
                    <p class="mb-sm"><strong>Band Name:</strong> <%= band.name %></p>
                    <p class="mb-sm"><strong>Email:</strong> <%= band.email %></p>

                    <% if (band.folder_id) { %>
                        <div class="border-t pt-base mt-base">
                            <h3 class="mb-base">Google Drive Resources</h3>
                            <p>
                                <a href="https://drive.google.com/drive/folders/<%= band.folder_id %>" target="_blank">
                                    View Band Folder
                                </a>
                            </p>
                        </div>
                    <% } %>
                </div>

                <div class="card mb-lg">
                    <form action="/account/password" method="POST" class="form">
                        <h2 class="card-title">Change Password</h2>

                        <div class="form-group">
                            <label for="currentPassword" class="form-label">Current Password</label>
                            <input type="password" id="currentPassword" name="currentPassword" class="form-input" required>
                        </div>

                        <div class="form-group">
                            <label for="newPassword" class="form-label">New Password</label>
                            <input type="password" id="newPassword" name="newPassword" class="form-input" required>
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword" class="form-label">Confirm New Password</label>
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" required>
                        </div>

                        <button type="submit" class="btn btn-primary">Update Password</button>
                    </form>
                </div>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
