<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Invoices - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">Invoices</h1>
            <%- include('partials/messages') %>

            <div class="card mb-xl">
                <div class="flex justify-between items-center mb-lg flex-wrap gap-base">
                    <div>
                        <p class="text-lg">
                            <%= invoices.length %> invoice<%= invoices.length !== 1 ? 's' : '' %>
                        </p>
                    </div>
                    <div>
                        <a href="<%= urlPrefix %>/new" class="btn btn-primary">New Invoice</a>
                    </div>
                </div>

                <!-- Filters -->
                <div class="mb-lg flex gap-sm flex-wrap">
                    <a
                        href="<%= urlPrefix %><%= isAdmin && bandFilter ? '?band=' + bandFilter : '' %>"
                        class="btn btn-sm <%= !statusFilter ? 'active' : '' %>"
                    >
                        All
                    </a>
                    <a
                        href="<%= urlPrefix %>?status=draft<%= isAdmin && bandFilter ? '&band=' + bandFilter : '' %>"
                        class="btn btn-sm <%= statusFilter === 'draft' ? 'active' : '' %>"
                    >
                        Draft
                    </a>
                    <a
                        href="<%= urlPrefix %>?status=sent<%= isAdmin && bandFilter ? '&band=' + bandFilter : '' %>"
                        class="btn btn-sm <%= statusFilter === 'sent' ? 'active' : '' %>"
                    >
                        Sent
                    </a>
                    <a
                        href="<%= urlPrefix %>?status=paid<%= isAdmin && bandFilter ? '&band=' + bandFilter : '' %>"
                        class="btn btn-sm <%= statusFilter === 'paid' ? 'active' : '' %>"
                    >
                        Paid
                    </a>
                    <a
                        href="<%= urlPrefix %>?status=cancelled<%= isAdmin && bandFilter ? '&band=' + bandFilter : '' %>"
                        class="btn btn-sm <%= statusFilter === 'cancelled' ? 'active' : '' %>"
                    >
                        Cancelled
                    </a>
                </div>

                <% if (isAdmin && bands && bands.length > 0) { %>
                    <div class="mb-lg">
                        <form action="<%= urlPrefix %>" method="GET" class="flex gap-base items-center">
                            <label for="band" class="form-label">Band:</label>
                            <select id="band" name="band" class="form-select" onchange="this.form.submit()">
                                <option value="">All bands</option>
                                <% bands.forEach(b => { %>
                                    <option value="<%= b.id %>" <%= bandFilter == b.id ? 'selected' : '' %>><%= b.name %></option>
                                <% }); %>
                            </select>
                            <% if (statusFilter) { %>
                                <input type="hidden" name="status" value="<%= statusFilter %>">
                            <% } %>
                        </form>
                    </div>
                <% } %>

                <!-- Invoice Table -->
                <% if (invoices.length > 0) { %>
                    <div class="table-wrapper">
                        <table class="table table-clickable">
                            <thead>
                                <tr>
                                    <th>Number</th>
                                    <th>Date</th>
                                    <% if (isAdmin) { %>
                                        <th>Band</th>
                                    <% } %>
                                    <th>Client</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% invoices.forEach(invoice => { %>
                                    <tr data-href="<%= urlPrefix %>/<%= invoice.id %>">
                                        <td><%= invoice.invoice_number %></td>
                                        <td><%= new Date(invoice.issue_date).toLocaleDateString('en-US') %></td>
                                        <% if (isAdmin) { %>
                                            <td><%= invoice.band_name %></td>
                                        <% } %>
                                        <td><%= invoice.client_name.length > 30 ? invoice.client_name.substring(0, 30) + '...' : invoice.client_name %></td>
                                        <td class="text-right"><%= invoice.total_amount.toFixed(2) %> EUR</td>
                                        <td>
                                            <% if (invoice.status === 'draft') { %>
                                                <span class="badge">DRAFT</span>
                                            <% } else if (invoice.status === 'sent') { %>
                                                <span class="badge badge-warning">SENT</span>
                                            <% } else if (invoice.status === 'paid') { %>
                                                <span class="badge badge-success">PAID</span>
                                            <% } else if (invoice.status === 'cancelled') { %>
                                                <span class="badge badge-error">CANCELLED</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-center">No invoices found.</p>
                <% } %>
            </div>

            <div class="mt-xl">
                <a href="/tools" class="btn btn-secondary">Back to Tools</a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        // Make rows clickable
        document.querySelectorAll('.table-clickable tbody tr[data-href]').forEach(row => {
            row.addEventListener('click', function() {
                window.location.href = this.dataset.href;
            });
        });
    </script>
</body>
</html>
