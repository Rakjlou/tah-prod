<% if (isAdmin) { %>
<div class="card mb-lg">
    <h2 class="card-title">Qonto</h2>

    <%
        let isValid = false;
        let linkedTotal = 0;
        let expectedTotal = 0;
        let difference = 0;
        const hasLinks = linkedQontoTransactions && linkedQontoTransactions.length > 0;

        if (hasLinks) {
            linkedTotal = linkedQontoTransactions.reduce((sum, link) => sum + (link.allocated_amount || link.qonto_amount || 0), 0);
            expectedTotal = transaction.type === 'expense' ? -transaction.amount : transaction.amount;
            difference = Math.abs(linkedTotal - expectedTotal);
            isValid = difference < 0.01;
        }
    %>

    <!-- Validation Status - Compact -->
    <div id="validation-status" class="qonto-validation-status mb-base">
        <div class="flex items-center gap-lg flex-wrap">
            <span>
                <strong>Website:</strong>
                <%= transaction.type === 'expense' ? '-' : '+' %><%= transaction.amount.toFixed(2) %> €
            </span>
            <% if (hasLinks) { %>
                <span class="text-muted">→</span>
                <span>
                    <strong>Linked:</strong> <%= linkedTotal.toFixed(2) %> €
                </span>
                <% if (isValid) { %>
                    <span class="badge badge-success">Match</span>
                <% } else { %>
                    <span class="badge badge-error">Discrepancy: <%= difference.toFixed(2) %> €</span>
                <% } %>
            <% } else { %>
                <span class="text-muted">No bank transactions linked</span>
            <% } %>
        </div>
    </div>

    <!-- Currently linked transactions -->
    <% if (hasLinks) { %>
        <div class="qonto-linked-transactions mb-base">
            <div class="table-wrapper">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th class="numeric">Amount</th>
                            <th>Counterparty</th>
                            <th>Reference</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% linkedQontoTransactions.forEach(link => { %>
                            <tr>
                                <td><%= link.qonto_settled_at ? new Date(link.qonto_settled_at).toLocaleDateString() : '-' %></td>
                                <td class="numeric">
                                    <%= (link.allocated_amount || link.qonto_amount) %> <%= link.qonto_currency || 'EUR' %>
                                    <% if (link.allocated_amount && Math.abs(link.allocated_amount) < Math.abs(link.qonto_amount)) { %>
                                        <span class="text-muted small"> / <%= link.qonto_amount %></span>
                                    <% } %>
                                </td>
                                <td><%= link.qonto_label || '-' %></td>
                                <td><%= link.qonto_reference || '-' %></td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-error" onclick="unlinkQonto(<%= link.id %>)">
                                        Unlink
                                    </button>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>

    <!-- Search button - only show if not matched -->
    <% if (!isValid) { %>
        <button type="button" class="btn btn-secondary" onclick="searchQontoMatches()" id="search-qonto-btn">
            Search Qonto Transactions
        </button>
    <% } %>

    <!-- Loading indicator -->
    <div id="qonto-loading" class="hidden qonto-loading">
        <p>Searching Qonto transactions...</p>
    </div>

    <!-- Error display -->
    <div id="qonto-error" class="hidden qonto-error"></div>

    <!-- Results container -->
    <div id="qonto-matches" class="hidden qonto-matches">
        <h3 class="qonto-small-section-title">Qonto Transactions:</h3>
        <div id="qonto-matches-content"></div>
        <button type="button" class="btn qonto-link-btn" onclick="linkSelected()" id="link-selected-btn">
            Link Selected
        </button>
    </div>

    <!-- Template for Qonto transaction table -->
    <template id="qonto-table-template">
        <div class="table-wrapper">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th class="qonto-checkbox-header"><input type="checkbox" id="select-all-qonto" onclick="toggleSelectAll()"></th>
                        <th>Date</th>
                        <th class="numeric">Available</th>
                        <th>Counterparty</th>
                        <th>Reference</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="qonto-table-body"></tbody>
            </table>
        </div>
        <p class="small text-muted mt-sm">Available = Remaining amount that can be allocated</p>
    </template>

    <!-- Template for Qonto transaction row -->
    <template id="qonto-row-template">
        <tr>
            <td><input type="checkbox" class="qonto-checkbox" data-qonto-id=""></td>
            <td class="qonto-date">-</td>
            <td class="qonto-available numeric">N/A</td>
            <td class="qonto-label">-</td>
            <td class="qonto-reference">-</td>
            <td class="qonto-status">completed</td>
        </tr>
    </template>

    <!-- Load Qonto Linker JavaScript -->
    <script src="/js/qonto-linker.js"></script>
</div>
<% } %>
