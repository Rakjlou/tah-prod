<nav class="navbar">
    <div class="navbar-container">
        <a href="/" class="navbar-brand">TAH PROD</a>
        <ul class="nav-links">
            <% if (user) { %>
                <% if (hasRole(ROLES.ADMIN)) { %>
                    <li><a href="/bands" class="nav-link <%= req.path === '/bands' ? 'active' : '' %>">Bands</a></li>
                    <%
                    const adminDropdownItems = [
                        { name: 'Transactions', href: '/admin/transactions' },
                        { name: 'Qonto', href: '/admin/qonto' },
                        { name: 'Reconciliation', href: '/admin/reconciliation' }
                    ];
                    const dropdownCurrentPath = typeof req !== 'undefined' ? req.path : '';
                    %>
                    <%- include('nav-dropdown', { items: adminDropdownItems, currentPath: dropdownCurrentPath, label: 'Admin' }) %>
                    <%
                    const adminToolsDropdownItems = [
                        { name: 'Tools', href: '/tools' },
                        { name: 'Invoices', href: '/admin/invoices' }
                    ];
                    %>
                    <%- include('nav-dropdown', { items: adminToolsDropdownItems, currentPath: dropdownCurrentPath, label: 'Tools' }) %>
                    <%
                    const configDropdownItems = [
                        { name: 'Config', href: '/config' },
                        { name: 'Invoice Config', href: '/config/invoices' },
                        { name: 'Users', href: '/admin/users' }
                    ];
                    %>
                    <%- include('nav-dropdown', { items: configDropdownItems, currentPath: dropdownCurrentPath, label: 'Config' }) %>
                <% } else if (hasRole(ROLES.BAND)) { %>
                    <li><a href="/transactions" class="nav-link <%= req.path === '/transactions' ? 'active' : '' %>">Transactions</a></li>
                    <%
                    const bandToolsDropdownItems = [
                        { name: 'Tools', href: '/tools' },
                        { name: 'Invoices', href: '/invoices' }
                    ];
                    const bandDropdownCurrentPath = typeof req !== 'undefined' ? req.path : '';
                    %>
                    <%- include('nav-dropdown', { items: bandToolsDropdownItems, currentPath: bandDropdownCurrentPath, label: 'Tools' }) %>
                    <li><a href="/account" class="nav-link <%= req.path === '/account' ? 'active' : '' %>">My Account</a></li>
                <% } %>
                <li><a href="/logout" class="nav-link">Disconnect</a></li>
            <% } else { %>
                <li><a href="/login" class="nav-link">Login</a></li>
            <% } %>
        </ul>
    </div>
</nav>
