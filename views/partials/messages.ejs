<% if (typeof success !== 'undefined' && success) { %>
    <div class="message message-success">
        <%= success %>
    </div>
<% } %>
<% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="message message-success">
        <%= successMessage %>
    </div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
    <div class="message message-error">
        <%= error %>
    </div>
<% } %>
<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="message message-error">
        <%= errorMessage %>
    </div>
<% } %>
<% if (typeof warningMessage !== 'undefined' && warningMessage) { %>
    <div class="message message-warning">
        <%= warningMessage %>
    </div>
<% } %>
<script>
document.querySelectorAll('.message-success').forEach(function(el) {
    var text = el.textContent;
    var match = text.match(/Password:\s*(\S+)/);
    if (match) {
        var pw = match[1];
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'btn btn-sm';
        btn.style.marginLeft = '8px';
        btn.textContent = 'Copy password';
        btn.addEventListener('click', function() {
            navigator.clipboard.writeText(pw).then(function() {
                btn.textContent = 'Copied!';
                setTimeout(function() { btn.textContent = 'Copy password'; }, 2000);
            });
        });
        el.appendChild(btn);
    }
});
</script>
