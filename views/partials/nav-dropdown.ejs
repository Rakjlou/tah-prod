<%
// Nav Dropdown Partial (Rakui CSS - Pure CSS hover dropdown)
//
// Usage:
// include('partials/nav-dropdown', {
//     items: [
//         { name: 'Transactions', href: '/admin/transactions' },
//         { name: 'Qonto', href: '/admin/qonto' }
//     ],
//     currentPath: req.path,
//     label: 'Admin'
// })
//
// The component will automatically highlight the active item.

const isActive = items.some(item => item.href === currentPath);
%>
<li class="nav-dropdown">
    <span class="nav-dropdown-toggle <%= isActive ? 'active' : '' %>" tabindex="0"><%= label %></span>
    <div class="nav-dropdown-menu">
        <% items.forEach(item => { %>
            <a href="<%= item.href %>" class="nav-dropdown-item <%= item.href === currentPath ? 'active' : '' %>"><%= item.name %></a>
        <% }) %>
    </div>
</li>
