<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head', { title: 'Bands - Tah Prod' }) %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="section">
        <div class="container">
            <h1 class="mb-lg">Bands</h1>
            <%- include('partials/messages') %>

            <% if (!googleConfigured) { %>
                <div class="message message-info mb-xl">
                    <p>
                        Google integration not configured yet. Please configure it in the <a href="/config">Config section</a> first.
                    </p>
                </div>
            <% } else if (!isGoogleAuthenticated) { %>
                <div class="card mb-xl">
                    <p class="mb-base">
                        To create band spreadsheets, you need to authenticate with Google first.
                    </p>
                    <a href="/auth/google" class="btn btn-primary">
                        Authenticate with Google
                    </a>
                </div>
            <% } %>

            <% if (googleConfigured && isGoogleAuthenticated) { %>
            <div class="card mb-xl">
                <h2 class="card-title">Add New Band</h2>
                <form id="band-form" action="/bands" method="POST" class="form">
                    <div class="form-group">
                        <label for="name" class="form-label">Band Name</label>
                        <input type="text" id="name" name="name" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label for="email" class="form-label">Contact Email</label>
                        <input type="email" id="email" name="email" class="form-input" required>
                    </div>
                    <button type="submit" id="submit-btn" class="btn btn-primary">Create Band</button>
                </form>
            </div>
            <% } %>

            <% if (bands && bands.length > 0) { %>
                <h2 class="mb-lg">Existing Bands</h2>
                <div class="table-wrapper">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Folder</th>
                                <th>Created</th>
                                <th class="numeric">Balance</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bands.forEach(band => { %>
                                <tr>
                                    <td><%= band.name %></td>
                                    <td><%= band.email %></td>
                                    <td>
                                        <% if (band.folder_id) { %>
                                            <a href="https://drive.google.com/drive/folders/<%= band.folder_id %>" target="_blank">View Folder</a>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </td>
                                    <td><%= new Date(band.created_at).toLocaleDateString() %></td>
                                    <td class="numeric <%= band.balance < 0 ? 'stat-warning' : '' %>">
                                        <%= band.balance.toFixed(2) %> &euro;
                                    </td>
                                    <td>
                                        <div class="flex gap-sm">
                                            <form action="/admin/bands/<%= band.id %>/reset-password" method="POST" style="display:inline;">
                                                <button type="submit"
                                                        class="btn btn-sm btn-icon"
                                                        title="Reset password"
                                                        aria-label="Reset password for <%= band.name %>">&#x21BB;</button>
                                            </form>
                                            <button type="button"
                                                    class="btn btn-sm btn-icon"
                                                    id="credentials-toggle-<%= band.id %>"
                                                    title="Manage credentials"
                                                    aria-label="Manage credentials for <%= band.name %>"
                                                    aria-expanded="false"
                                                    aria-controls="credentials-<%= band.id %>"
                                                    onclick="toggleCredentials(<%= band.id %>)">&#x25B8;</button>
                                            <form action="/admin/bands/<%= band.id %>/delete" method="POST" style="display:inline;">
                                                <button type="submit"
                                                        class="btn btn-sm btn-icon btn-error"
                                                        title="Delete band"
                                                        aria-label="Delete band <%= band.name %>"
                                                        onclick="return confirm('Are you sure you want to delete <%= band.name %>? This will delete the band, user account, all transactions, and Google Drive folder. This action cannot be undone.')">&#x2717;</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <tr id="credentials-<%= band.id %>" style="display: none;">
                                    <td colspan="6">
                                        <div class="card" style="margin: 0;">
                                            <h3 class="mb-base">Credentials for <%= band.name %></h3>

                                            <table class="table mb-base">
                                                <thead>
                                                    <tr>
                                                        <th>Label</th>
                                                        <th>Username</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td>Main</td>
                                                        <td><%= band.email %></td>
                                                        <td>
                                                            <form action="/admin/bands/<%= band.id %>/reset-password" method="POST" class="flex gap-sm" style="align-items: center;">
                                                                <input type="password" name="password" class="form-input form-input-sm" placeholder="Leave empty for random" style="width: 200px;">
                                                                <button type="submit"
                                                                        class="btn btn-sm btn-icon"
                                                                        title="Reset password"
                                                                        aria-label="Reset main password for <%= band.name %>">&#x21BB;</button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    <% const bandCreds = credentialsByBandId[band.id] || []; %>
                                                    <% bandCreds.forEach(cred => { %>
                                                        <tr>
                                                            <td><%= cred.label %></td>
                                                            <td><%= cred.username %></td>
                                                            <td>
                                                                <div class="flex gap-sm">
                                                                    <form action="/admin/bands/<%= band.id %>/credentials/<%= cred.id %>/reset-password" method="POST" class="flex gap-sm" style="align-items: center;">
                                                                        <input type="password" name="password" class="form-input form-input-sm" placeholder="Leave empty for random" style="width: 200px;">
                                                                        <button type="submit"
                                                                                class="btn btn-sm btn-icon"
                                                                                title="Reset password"
                                                                                aria-label="Reset password for credential <%= cred.label %>">&#x21BB;</button>
                                                                    </form>
                                                                    <form action="/admin/bands/<%= band.id %>/credentials/<%= cred.id %>/delete" method="POST" style="display:inline;">
                                                                        <button type="submit"
                                                                                class="btn btn-sm btn-icon btn-error"
                                                                                title="Delete credential"
                                                                                aria-label="Delete credential <%= cred.label %>"
                                                                                onclick="return confirm('Delete credential \'<%= cred.label %>\'?')">&#x2717;</button>
                                                                    </form>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>

                                            <h4 class="mb-sm">Add Credential</h4>
                                            <form action="/admin/bands/<%= band.id %>/credentials" method="POST" class="flex gap-sm flex-wrap" style="align-items: flex-end;">
                                                <div class="form-group" style="margin-bottom: 0;">
                                                    <label class="form-label">Label</label>
                                                    <input type="text" name="label" class="form-input" placeholder="e.g. Manager" required>
                                                </div>
                                                <div class="form-group" style="margin-bottom: 0;">
                                                    <label class="form-label">Username</label>
                                                    <input type="text" name="username" class="form-input" placeholder="e.g. manager@example.com" required>
                                                </div>
                                                <div class="form-group" style="margin-bottom: 0;">
                                                    <label class="form-label">Password (optional)</label>
                                                    <input type="password" name="password" class="form-input" placeholder="Leave empty for random">
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary">Add</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <p class="empty-state-text">No bands created yet.</p>
                </div>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/bands.js"></script>
</body>
</html>
